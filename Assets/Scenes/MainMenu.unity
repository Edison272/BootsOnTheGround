    m_PersistentCalls:
      m_Calls: []
  m_text: 'COMMANDING OPERATORS


    1)  1-4 to Select an Operator


    2)  Move
    Cursor to a target location, then Hold LMB to fully open the Operator''s Action
    Wheel


    3)  While Holding LMB, move the mouse to interact with the Action
    Wheel options.


    - Selector must SNAP to the a selected action to select
    it.



    4) Release LMB to confirm the action if an action is selected in the
    action wheel, or cancel the action if nothing is selected


'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
