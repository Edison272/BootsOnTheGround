  m_CreationSettings:
    sourceFontFileName: 
    sourceFontFileGUID: bcfb9bb30ceb7b348bc82aceabd97033
    faceIndex: 0
    pointSizeSamplingMode: 0
    pointSize: 93
    padding: 4
    paddingMode: 1
    packingMode: 4
    atlasWidth: 1024
    atlasHeight: 1024
    characterSetSelectionMode: 7
    characterSequence: "\uC2DC\uC791\r\n\uC9C0\uCE68\r\n\uC124\uC815\r\n\uD604\uC7A5
      \uD22C\uC785\r\n\uCD9C\uAD6C\r\n\uC548\uB155\uD558\uC138\uC694\r\n\uC9C0\uB3C4
      \uC2DC\uAC04\r\n\uBC18\uD488\r\n\"\uAE30\uBCF8 \uC870\uC791\n\n- WASD \uD0A4\uB85C
      \uC774\uB3D9\n\n- E \uD0A4\uB85C \uBB34\uAE30 \uC804\uD658\n\n- R \uD0A4\uB85C
      \uC7AC\uC7A5\uC804\n\n- SPACE \uD0A4\uB85C \uAD11\uAC01 \uC2DC\uC810 \uC804\uD658\n\n-
      \uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC(LMB)\uC73C\uB85C \uC0AC\uACA9
      (\uC870\uC885\uC0AC\uB97C \uC9C0\uD718\uD558\uC9C0 \uC54A\uC744 \uB54C)\n\n-
      \uB9C8\uC6B0\uC2A4 \uC624\uB978\uCABD \uBC84\uD2BC(RMB)\uC73C\uB85C \uBCF4\uC870
      \uBB34\uAE30 \uC0AC\uACA9 (\uC591\uC190 \uBB34\uAE30 \uC0AC\uC6A9 \uC2DC)\"\r\n\"\uC870\uC791\uC790
      \uC120\uD0DD\n\n1) 1-4\uBC88\uC744 \uB20C\uB7EC \uC870\uC791\uC790\uB97C \uC120\uD0DD\uD569\uB2C8\uB2E4.\n\n2)
      \uCEE4\uC11C\uB97C \uC6D0\uD558\uB294 \uC704\uCE58\uB85C \uC774\uB3D9\uD55C
      \uB2E4\uC74C \uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC(LMB)\uC744 \uAE38\uAC8C
      \uB20C\uB7EC \uC870\uC791\uC790\uC758 \uC561\uC158 \uD720\uC744 \uC644\uC804\uD788
      \uC5FD\uB2C8\uB2E4.\n\n3) LMB\uB97C \uB204\uB978 \uC0C1\uD0DC\uC5D0\uC11C \uB9C8\uC6B0\uC2A4\uB97C
      \uC6C0\uC9C1\uC5EC \uC561\uC158 \uD720\uC758 \uC635\uC158\uC744 \uC120\uD0DD\uD569\uB2C8\uB2E4.\n\n-
      \uC120\uD0DD\uD558\uB824\uBA74 \uB9C8\uC6B0\uC2A4 \uCEE4\uC11C\uAC00 \uC120\uD0DD\uB41C
      \uC561\uC158\uC5D0 \uC815\uD655\uD788 \uB9DE\uCDB0\uC838\uC57C \uD569\uB2C8\uB2E4.\n\n4)
      \uC561\uC158 \uD720\uC5D0\uC11C \uC561\uC158\uC774 \uC120\uD0DD\uB418\uBA74
      LMB\uB97C \uB193\uC544 \uC561\uC158\uC744 \uD655\uC815\uD558\uACE0, \uC544\uBB34\uAC83\uB3C4
      \uC120\uD0DD\uB418\uC9C0 \uC54A\uC73C\uBA74 \uC561\uC158\uC744 \uCDE8\uC18C\uD569\uB2C8\uB2E4.\n\n\"\r\n\uD654\uC774\uD2B8\uC874\uC744
      \uBAA8\uB450 \uC810\uB839\uD558\uBA74 \uC2B9\uB9AC\uD569\uB2C8\uB2E4!\r\n\uBC88\uC5ED\uD558\uB2E4\r\n\uC601\uC5B4\r\n\uC911\uAD6D\uC5B4\r\n\uC77C\uBCF8\uC5B4"
